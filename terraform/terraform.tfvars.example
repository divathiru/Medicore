# =============================================================================
# MediCore — terraform.tfvars.example
# Copy to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars — it is in .gitignore.
# =============================================================================

aws_region            = "us-east-1"
environment           = "dev"
db_instance_class     = "db.t3.micro"
service_desired_count = 1

# Your GHCR registry prefix (your GitHub username or org)
ghcr_registry = "ghcr.io/YOUR_GITHUB_USERNAME"

# Your GitHub repo slug for OIDC (owner/repo-name)
github_repo = "YOUR_GITHUB_USERNAME/medicore"

# Mistral API key — do not commit
# Pass via: terraform apply -var="mistral_api_key=$MISTRAL_API_KEY"
mistral_api_key = "REPLACE_ME"

# =============================================================
# MediCore main-website — environment variables
# Copy to .env and fill in real values. NEVER commit .env.
# =============================================================
PORT=4000
DATABASE_URL=postgres://medicore:medicore_dev@postgres:5432/medicore
JWT_SECRET=change_me_to_a_long_random_secret_in_production
# Downstream service URLs (Docker network names)
PATIENT_SERVICE_URL=http://patient-service:4001
DOCTOR_SERVICE_URL=http://doctor-service:4002
CASHIER_SERVICE_URL=http://cashier-service:4003
AI_SERVICE_URL=http://ai-service:5000
# For local dev outside Docker, use localhost:
# PATIENT_SERVICE_URL=http://localhost:4001
# DOCTOR_SERVICE_URL=http://localhost:4002
# CASHIER_SERVICE_URL=http://localhost:4003
# AI_SERVICE_URL=http://localhost:5000
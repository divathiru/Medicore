# =============================================================
# MediCore Monorepo — .gitignore
# =============================================================
# ----- Node -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
# ----- Python -----
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
dist/
*.egg-info/
# ----- Environment / Secrets (NEVER commit real .env files) -----
.env
*.env
!*.env.example
# ----- Docker volumes -----
postgres-data/
uploads/
# ----- Build artifacts -----
dist/
build/
.next/
# ----- IDE -----
.vscode/
.idea/
*.swp
*.swo
# ----- OS -----
.DS_Store
Thumbs.db
# ----- Logs -----
logs/
*.log
# ----- Coverage -----
coverage/
.nyc_output/
htmlcov/

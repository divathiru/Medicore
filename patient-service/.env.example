# =============================================================
# MediCore patient-service — environment variables
# Copy to .env and fill in real values. NEVER commit .env.
# =============================================================
PORT=4001
DATABASE_URL=postgres://medicore:medicore_dev@postgres:5432/medicore
JWT_SECRET=change_me_to_a_long_random_secret_in_production
# AI service URL (Docker network name or localhost for dev)
AI_SERVICE_URL=http://ai-service:5000
# AI_SERVICE_URL=http://localhost:5000

# ── S3 — Patient uploads ───────────────────────────────────────
# Bucket for patient medical summary uploads.
# On ECS Fargate: leave AWS_* vars unset — the task role is assumed automatically.
# In local dev outside Docker: set AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY,
# and AWS_REGION pointing at a real S3 bucket.
# LocalStack is out of scope — see README "Known Simplifications".
S3_BUCKET_NAME=medicore-dev-patient-uploads
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=     # only for local dev — never commit real keys
# AWS_SECRET_ACCESS_KEY= # only for local dev — never commit real keys

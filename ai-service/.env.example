# =============================================================
# ai-service — .env.example
# Copy to .env and fill in real values.  Never commit .env.
# =============================================================

# Mistral AI API key (get from https://console.mistral.ai/)
MISTRAL_API_KEY=your_mistral_api_key_here

# PostgreSQL connection string (same instance shared across all services)
DATABASE_URL=postgres://medicore:medicore_dev@postgres:5432/medicore

# Service port (must match docker-compose.yml)
PORT=5000
